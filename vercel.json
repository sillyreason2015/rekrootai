{
  "buildCommand": "cd CLIENT && npm install && npm run build",
  "outputDirectory": "CLIENT/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://rekroot-ai-bck.onrender.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
