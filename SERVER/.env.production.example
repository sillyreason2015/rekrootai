LIVEKIT_API_KEY=YOUR_LIVEKIT_API_KEY
LIVEKIT_API_SECRET=YOUR_LIVEKIT_API_SECRET
LIVEKIT_HOST=wss://yourproject.livekit.cloud

ML_SERVICE_URL=https://your-ml-service-domain.com
