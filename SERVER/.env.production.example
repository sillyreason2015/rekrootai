NODE_ENV=production
PORT=5000
CORS_ORIGIN=https://rekroot-ai.vercel.app

MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster.mongodb.net/integra-hire?retryWrites=true&w=majority

